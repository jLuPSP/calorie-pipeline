# Copy to .env and adjust. Every value has a working default; nothing here is
# required for the offline tests or `python -m evals.harness`.

# --- USDA FoodData Central ----------------------------------------------------
# DEMO_KEY works with no signup (rate-limited: ~30 req/hr, 50/day per IP).
# Free unlimited-ish key (instant, email only): https://fdc.nal.usda.gov/api-key-signup
FDC_API_KEY=DEMO_KEY
# Ordered fallback across FDC data types (comma-separated). Foundation is the
# highest quality but thin (alone it grounds ~1/7 real meal ingredients); the
# chain below grounds ~7/7. Set to "Foundation" to force lab-measured purity.
# FDC_DATA_TYPE=Foundation, SR Legacy, Survey (FNDDS)
# FDC_PAGE_SIZE=1

# --- Ollama -------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
# OLLAMA_HOST=http://tower.local:11434   # or a remote box on your LAN

# --- Models -------------------------------------------------------------------
# The thesis is about 7B. A bigger box swaps these with ZERO code changes.
VISION_MODEL=qwen2.5vl:7b
TEXT_MODEL=qwen2.5:7b

# --- Matching -----------------------------------------------------------------
# Let the text model PICK the USDA match from real candidates (a judgment, not a
# heuristic). Best single-pipeline matcher on the benchmark (141 -> 125 MAE);
# costs one model call per ingredient, so OFF by default.
# LLM_MATCH=1

# Blend weight on the one-shot in the recommended combined answer. The one-shot
# and the decomposed pipeline make weakly-correlated errors, so the blend beats
# either alone; ~0.65 is the benchmark inverse-variance optimum.
# COMBINE_WEIGHT=0.65

# Semantic (embedding) re-ranking — OFF by default: nicer individual matches but
# WORSE aggregate error than keyword matching. Opt in with SEMANTIC_MATCH=1.
# SEMANTIC_MATCH=0
# EMBED_MODEL=nomic-embed-text
